{
  "description": "Garry's Count - tracks how many lines of code Claude Code writes per day",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/count-hook.sh"
          }
        ]
      }
    ]
  }
}
